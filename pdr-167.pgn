[Site "London"]
[Date "2000.10.19"]
[Round "7"]
[White "Kasparov, Garry"]
[Black "Kramnik, Vladimir"]
[Result "1/2-1/2"]
[ECO "A32"]
[WhiteElo "2849"]
[BlackElo "2770"]
[Annotator "Illescas Cordoba,Miguel"]
[PlyCount "21"]
[EventDate "2000.10.08"]
[EventType "match"]
[EventRounds "15"]
[EventCountry "ENG"]
[SourceTitle "CBM 080"]
