[Site "Campinas BRA"]
[Date "2011.12.19"]
[Round "10"]
[White "Fier, A.."]
[Black "Santiago, Y.."]
[Result "1-0"]
[ECO "A13"]
[BlackElo "2335"]
[Annotator "Adla Martin"]
[SetUp "1"]
[FEN "r1bq1rk1/p3bppp/1pn1p3/8/3P4/2PB1N2/P4PPP/R1BQR1K1 w - - 0 12"]
[PlyCount "17"]
