{[%evp 0,73,13,13,50,32,43,60,53,50,44,18,33,45,44,-8,-8,29,44,25,44,30,24,24,32,32,26,37,46,13,57,72,48,58,59,62,63,62,65,58,71,72,56,55,57,51,42,55,37,17,17,-17,104,104,117,132,129,109,100,108,215,191,144,105,335,348,345,376,380,372,412,381,410,405,711,734]} 1. e4 c5 {la siciliana suele ser la elección cuando se está obligado a ganar con negras} 2. Nf3 Nc6 3. Bb5 e6 4. O-O (4. Bxc6 {fue la preferida de anand en su match por el Campeonato del Mundo ante gelfand en 2012}) 4... Nge7 5. Re1 b6 6. c3 a6 7. Be2 (7. Ba4 c4) 7... d5 8. exd5 Nxd5 9. d4 Be7 10. c4 Nf6 11. dxc5 Qxd1 12. Rxd1 bxc5 13. Nc3 Bb7 14. Na4 Rc8 (14... Nd7 $5 15. Be3 e5 $1) 15. Be3 Nb8 16. Ne5 $1 Nbd7 {[#]} 17. Nxd7 (17. Bf3 $1 Bxf3 18. Nxf3 $14) 17... Nxd7 18. Rd2 (18. Rxd7 Kxd7 19. Nb6+ Kc7 20. Nxc8 Rxc8 21. Rd1 $11) 18... Bc6 $11 19. Nc3 h5 20. Rad1 f5 (20... Ne5 $5 21. h3 g5 $1 $15) 21. f4 Nf6 22. b3 Kf7 (22... Ng4 $5 23. Bxg4 fxg4 $5 24. Bf2 h4) 23. Bf3 $1 Ng4 24. Bxg4 $6 (24. Bf2 $5 Bxf3 25. gxf3 Nxf2 26. Kxf2 Rhd8 $11) 24... hxg4 25. Ne2 e5 $6 (25... g5 $1 26. fxg5 e5 27. g3 Bf3) 26. fxe5 g5 27. Nc3 f4 28. Bf2 Rh6 $1 29. Nd5 Rch8 30. Nxe7 (30. e6+ $5 Rxe6 31. Nxe7 Rxe7 32. Bxc5 Re6 33. Rd6 Rhe8 $11) 30... Rxh2 {[#]} 31. Bh4 $1 (31. Bxc5 Rh1+ (31... g3 32. e6+) 32. Kf2 g3+ 33. Ke2 Bxg2) 31... R8xh4 (31... Rxg2+ $1 32. Rxg2 Bxg2 33. e6+ (33. Kxg2 f3+ 34. Kg3 gxh4+ 35. Kxg4 Kxe7 $11) 33... Kxe6 34. Ng6 Bf3) 32. Nxc6 g3 33. Kf1 f3 34. Rd7+ $1 (34. gxf3 $2 Rxd2 35. Rxd2 Rh1+ 36. Kg2 Rh2+ 37. Kxg3 Rxd2 $11) 34... Ke6 35. Re7+ Kf5 36. Rf7+ Ke4 37. Re1+ {[#]} 1-0

