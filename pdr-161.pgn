[Round "?"]
[White "Escobar Alfaro, Salvador"]
[Black "Ramirez Garcia, Jorge Alberto"]
[Result "1-0"]
[ECO "A52"]
[WhiteElo "2050"]
[BlackElo "2223"]
[Annotator "Jorge Ramírez"]
[PlyCount "63"]
[EventDate "2007.??.??"]
[EventType "swiss"]
