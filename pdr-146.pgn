[Annotator "Arizmendi"]
[SetUp "1"]
[FEN "1rq1r1k1/p2bppbp/6p1/2pP2B1/2p1PP2/2P3N1/P2Q2PP/1R3RK1 w - - 0 21"]
[PlyCount "19"]
