[FEN "r1bq1rk1/p1pn2bp/1p1ppnp1/8/2P1P3/2N2N2/PPQ1BPPP/R1B2RK1 w - - 0 1"]
[PlyCount "0"]
[EventDate "2022.??.??"]

{[#] [#]  Posición 1 
