{[%evp 0,271,25,26,18,18,11,-3,14,7,26,18,17,-5,-9,-9,-6,-12,-24,-12,-23,-14,
-14,-18,-30,0,-16,13,8,-15,-20,-23,-20,-23,-42,-54,-42,-33,-24,-23,-24,-21,-16,
-14,-9,1,-12,5,0,0,12,0,36,48,58,18,25,10,36,48,27,-35,38,0,25,25,18,-56,-52,
