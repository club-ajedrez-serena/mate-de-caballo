[Black "Karpov, Anatoly"]
[Result "0-1"]
[ECO "E55"]
[SetUp "1"]
[FEN "2rq1rk1/p2n1ppp/Qp2pn2/8/3P4/2P2N2/P2B1PPP/R2R2K1 b - - 0 15"]
[PlyCount "49"]
