[ECO "A29"]
[WhiteElo "2783"]
[BlackElo "2807"]
[Annotator "Jose"]
[SetUp "1"]
[FEN "3rr1k1/pp3ppp/2n1b3/1p2p2q/1P6/2BP1PP1/P1RQP1BP/5RK1 w - - 0 19"]
[PlyCount "21"]
