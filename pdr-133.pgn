[Event "Gibraltar Masters 2018"]
[Site "Caleta ENG"]
[Date "2018.01.30"]
[Round "8.32"]
[White "Huzman, Alexander"]
[Black "Henderson de La Fuente, Lance"]
[Result "0-1"]
