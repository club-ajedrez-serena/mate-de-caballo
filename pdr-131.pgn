[Black "Grischuk, Alexander"]
[Result "1/2-1/2"]
[ECO "B09"]
[WhiteElo "2754"]
[BlackElo "2710"]
[Annotator "Martin, A"]
[SetUp "1"]
[FEN "8/8/r7/P5k1/1K2p3/R5P1/8/8 w - - 0 50"]
[PlyCount "36"]
[EventDate "2005.01.15"]
[EventRounds "13"]
[EventCountry "NED"]
