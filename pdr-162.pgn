[Date "????.??.??"]
[Round "3.1"]
[White "Lichtenhein, Theodor"]
[Black "Morphy, Paul"]
[Result "0-1"]
[ECO "C56"]
[Annotator "Jorge"]
[PlyCount "38"]
[EventDate "1857.10.06"]
[EventType "k.o."]
[EventRounds "4"]
[EventCountry "USA"]
