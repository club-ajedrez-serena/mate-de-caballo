[Event "Candidates Tournament"]
[Site "Bled/Zagreb/Belgrade"]
[Date "1959.??.??"]
[Round "?"]
[White "Fischer, Robert James"]
[Black "Smyslov, Vassily"]
[Result "0-1"]
