0,13,4,-7,0,-5,9,1,21,3,32,26,26,26,31,26,27,27,48,42,109,76,76,73,74,79,87,76,
76,70,69,69,69,69,76,75,71,62,89,94,86,86,71,68,76,63,69,63,69,72,72,61,65,60,
67,62,95,104,104,111,111,80,132,94,92,92,92,85,85,85,123,124,128,84,83,84,92,
74,74,74,79,79,78,61,78,78,78,74,78,56,78,78,78,40,78,78,78,78,85,78,78,39,78,
