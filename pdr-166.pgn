[Site "?"]
[Date "1993.??.??"]
[Round "?"]
[White "Rigan, Josef"]
[Black "Yandemirov, Valery"]
[Result "0-1"]
[Annotator "Diego Alda"]
[SetUp "1"]
[FEN "8/5k2/1R6/1pr3p1/6P1/1K6/8/8 b - - 0 1"]
