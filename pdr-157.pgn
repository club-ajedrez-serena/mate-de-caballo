[Annotator "Adla Martin"]
[SetUp "1"]
[FEN "2rqkb1r/1b1n1ppp/pn1pp3/1p6/3NP1P1/2NBBP2/PPP2Q1P/1K1R3R b k - 0 13"]
[PlyCount "39"]
