[Event "Camp. provincial absoluto de Alicante"]
[Site "?"]
[Date "2016.11.??"]
[Round "?"]
[White "Mataix, César"]
[Black "Serarols, Bernat"]
[Result "0-1"]
[ECO "C00"]
[WhiteElo "2063"]
[BlackElo "2268"]
