{[%evp 0,77,20,20,26,35,26,7,-10,-18,19,11,16,-3,50,6,11,26,32,32,55,44,66,58,
58,49,91,17,83,-10,-14,-2,-13,-5,-16,-12,16,20,14,20,20,29,38,30,30,51,87,89,
68,68,68,68,62,48,69,69,92,88,65,59,71,47,86,63,65,47,65,136,104,113,79,283,
695,693,690,597,690,736,789,578] [#]} 32. g4 $1 {Al mejor estilo Botvinnik,
este avance en el flanco de rey crea una segunda debilidad en el flanco de rey
difícil de defender.} hxg4 33. hxg4 Rb7 34. Rc1 Qb5 $2 35. Qf3 $1 f6 36. g5 $1
Nf5 ({Pierden} 36... fxe5 37. Qf6+ Kg8 38. Rh1 $18) ({o} 36... f5 37. Qh3 $18 {
en ambos casos con ataque decisivo}) 37. gxf6+ Kxf6 38. Rxc6+ Ke7 39. Qf4 1-0

