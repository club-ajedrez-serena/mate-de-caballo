[WhiteElo "2496"]
[BlackElo "2618"]
[Annotator "Illescas,Miguel"]
[SetUp "1"]
[FEN "1r2k2r/p2q1p2/2Bpbnp1/4p3/Q7/2P3P1/P1P1PP2/2B1R1K1 b k - 0 20"]
