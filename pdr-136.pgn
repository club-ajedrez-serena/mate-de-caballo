1. cxd8=R+ {[#] ¿Qué pieza negra acaba de ser capturada?} *

[Event "?"]
[Site "?"]
[Date "2015.02.23"]
[Round "?"]
[White "Ajedrez retrógrado"]
[Black "?"]
[Result "*"]
[Annotator "Illescas,Miguel"]
