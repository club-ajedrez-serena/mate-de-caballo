{[%evp 0,130,26,28,28,-24,-23,-25,0,0,27,24,10,10,21,30,28,15,32,42,15,19,28,
26,67,34,79,59,74,37,43,22,22,-140,-97,-70,-84,-52,-32,-75,-70,-68,-84,-77,-71,
-71,-86,-86,-84,-76,-78,-78,-74,-124,-89,-130,-90,-174,-114,-100,-119,-91,-82,
-96,-64,-71,-68,-66,-84,-82,-95,-97,-94,-94,-75,-59,-65,-78,-89,-90,-107,-107,
-107,-131,-114,-134,-114,-132,-142,-145,-142,-145,-172,-191,-145,-142,-148,
-175,-153,-184,-175,-184,-184,-177,-189,-189,-200,-214,-243,-238,-275,-360,
-415,-424,-475,-481,-526,-548,-578,-712,-362,-362,-362,-609,-377,-482,-574,
-1160,-1008,-1014,-1043,-1043,-1049] [#]} 39... Ke6 $3 ({No es el tema} 39...
Rc3+ 40. Ke4 Rxa3 41. Rc2 {poco importa si las negras pueden o no ganar el
final, las blancas tienen una actividad inesperada que les permite luchar con
posibilidades. La jugada de la partida mantiene al blanco dominado.}) 40. Rb3
Kd5 41. Rd3 f5 {Muy lógico. Ganancia de espacio e inmovilización.} 42. h3 h5
43. Ke2 (43. h4 g6 {¿Que hace?. Nada. Zugzwang total.} 44. Rd2 Rc3+ 45. Rd3
Rxd3+ 46. Kxd3 a5 47. Kc3 Ke4 {Otro zugzwang total.}) 43... Rxd4 44. Rc3 ({
Obviamente si} 44. Re3 Re4 {pasa a un final de reyes ganador.}) 44... Re4+ 45.
Kd2 h4 46. Rc7 hxg3 ({Gana. pero era mejor la notable ruptura} 46... g5 $1 47.
gxh4 (47. fxg5 hxg3 {ganando.}) 47... gxh4 {y las negras ganan un segundo
peón.}) 47. Rxg7 Rxf4 48. Rxg3 Ke5 49. Ke2 Rc4 50. Rg6 Ra4 $1 {Atando a la
torre blanca.} 51. Rg3 f4 52. Rb3 Rc4 53. Kd1 Ke4 {Las negras aplican el
concepto "todos adelante". En el sistema que presento,
espacio-dominación-zugzwang.} 54. h4 f3 55. Ke1 {[#]} Kf4 $1 {Como muy bien
explicó Nimzovitch el concepto "todos adelante" es una cooperación perfecta
entre las piezas. Aquí el rey negro protege el avance del peón "f" mientras
que ese mismo peón "f" protege al rey negro de los jaques. También favorece
la iniciativa de la torre negra que generará figuras de mate contra el rey
blanco y de apoyo al peón "f".} 56. h5 Rc1+ 57. Kf2 Rc2+ 58. Ke1 Kg3 59. h6
Re2+ 60. Kd1 Rh2 61. a4 b4 62. h7 Rxh7 63. Rxb4 Rh1+ 64. Kd2 f2 65. Rb8 f1=Q {
Un clásico de los finales de torre.} 0-1

