{[%evp 0,163,14,13,21,15,18,22,3,21,17,8,24,18,32,31,28,26,22,47,25,-16,10,-11,15,24,6,-6,-4,-10,-12,-11,-16,-14,-66,-43,-132,-61,-69,-68,-49,-57,-67,-66,-56,-56,-41,-31,-41,-94,-77,-101,-96,-114,-158,-117,-193,-127,-127,-140,-111,-136,-125,-144,-90,-143,-11,-133,-111,-160,-180,-183,-110,-194,-184,-191,-217,-229,-184,-139,-130,-141,-92,-73,-151,-129,-140,-137,-148,-125,-167,-149,-139,-150,-73,-152,-170,-171,-104,-171,-104,-100,-86,-93,-75,-88,-59,-90,-8,-93,-113,-116,10,84,133,230,132,112,110,109,123,126,342,416,349,401,345,396,355,391,389,368,381,399,397,400,439,456,435,407,461,476,461,390,440,393,371,324,372,211,374,355,517,400,634,504,657,676,634,721,1215,1141,1257,1641,1689,1696]} 1. e4 e5 2. Nf3 Nc6 3. Bb5 a6 4. Ba4 Nf6 5. O-O d6 6. Re1 Bg4 7. c3 Be7 8. h3 Bh5 9. d3 Qd7 10. Bxc6 Qxc6 11. Bg5 Bg6 12. Nbd2 h6 13. Bxf6 Bxf6 14. Nf1 O-O 15. Ne3 Rae8 16. Qb3 Bd8 17. Qd5 Qxd5 18. Nxd5 f5 19. Nd2 Bf7 20. Ne3 f4 21. Nec4 Bf6 22. a4 Rd8 23. Na5 Rb8 24. Nf3 g5 25. Nh2 h5 26. Nc4 Be6 27. f3 Rfd8 28. Re2 Kf7 29. a5 Rg8 30. Ra4 Rbd8 31. Rb4 Bc8 32. b3 Rh8 33. Nb2 d5 34. exd5 Rxd5 35. Rc4 c6 36. b4 Bf5 37. Rd2 Rhd8 38. Kf2 {[#] Todos esperábamos 38…, Axd3, la toma de peón con el alfil. Sin embargo, Jan, confirmando la definición que hiciera de su juego el mismo Lasker, tras lograr la posición ganadora, no parece interesado en materializarla, en que acabe la partida, sino que hizo} Rb5 {sin ningún objetivo aparente, para luego volver con la torre de nuevo} 39. Ke2 Rbd5 {Curiosamente tras el siguiente movimiento de Lasker, volvía a tener la posibilidad de tomar y volvió a desestimar cambiar su alfil por el caballo del alemán:} 40. Kd1 Ke6 41. Kc2 Be7 42. Nf1 c5 43. bxc5 Bxc5 44. Ra4 R8d7 45. Rd1 Ba7 46. Ra3 g4 47. hxg4 hxg4 48. c4 R5d6 49. Nd2 Be3 50. Rh1 gxf3 51. gxf3 Rg7 52. Rh2 Bg1 53. Re2 Rg3 54. Nd1 Rd7 55. Rb3 Rdg7 56. Nc3 Be3 57. Nd5 Rg2 58. Rxe3 fxe3 59. Rb6+ Kd7 60. Nxe3 Kc7 61. Nxf5 Rh7 62. Nd6 Rhh2 63. N6e4 Rh1 64. Kc3 Rc1+ 65. Kb4 Rd1 66. Nb3 Rxd3 67. Rxb7+ Kc8 68. Rf7 Rb2 69. Nec5 Rd6 70. Rf5 Re2 71. Ne4 Rd3 72. Rxe5 Rb2 73. Nec5 Rxf3 74. Re8+ Kc7 75. Re6 Rc2 76. Nxa6+ Kb7 77. Nac5+ Ka7 78. Re7+ Ka8 79. Na4 Rh2 80. Nbc5 Kb8 81. Rb7+ Kc8 82. a6 1-0

