[Event "San Remo"]
[Site "San Remo"]
[Date "1930.01.18"]
[Round "3"]
[White "Alekhine, Alexander"]
[Black "Nimzowitsch, Aron"]
[Result "1-0"]
[ECO "C17"]
[Annotator "Donev,Ivo Hristov"]
[PlyCount "59"]
[EventDate "1930.01.15"]
[EventType "tourn"]
[EventRounds "15"]
[EventCountry "ITA"]
[SourceTitle "100 Jahre Schach"]
[Source "ChessBase"]
[SourceDate "2000.04.19"]
