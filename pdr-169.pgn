[Event "World-ch Kramnik-Kasparov +2-0=13"]
[Site "London"]
[Date "2000.10.21"]
[Round "8"]
[White "Kramnik, Vladimir"]
[Black "Kasparov, Garry"]
[Result "1/2-1/2"]
[ECO "E32"]
[WhiteElo "2770"]
[BlackElo "2849"]
[Annotator "Illescas Cordoba,Miguel"]
[PlyCount "75"]
[EventDate "2000.10.08"]
[EventType "match"]
[EventRounds "15"]
[EventCountry "ENG"]
