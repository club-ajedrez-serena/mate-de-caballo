[White "Gukesh, Dommaraju"]
[Black "Ding, Liren"]
[Result "0-1"]
[ECO "C54"]
[WhiteElo "2725"]
[BlackElo "2780"]
[Annotator "Illescas Cordoba,Miguel"]
