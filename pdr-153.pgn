[Annotator "Andrea"]
[SetUp "1"]
[FEN "r2q1rk1/3n3p/3p1bp1/2pPpp2/p1P5/2B2P2/PPB1Q1PP/3R1RK1 b - - 0 22"]
[PlyCount "33"]
